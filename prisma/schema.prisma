generator client {
  provider      = "prisma-client-js"
  // GitHub Actions(ubuntu / debian-openssl)で generate し Vercel(rhel-openssl)へ prebuilt デプロイするため両方のエンジンを生成する
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

/// 企業テーブル
/// 企業として登録された組織の情報
model Organization {
  id                 String   @id @default(uuid()) @db.Uuid
  companyName        String?  @map("company_name")
  industry           String?
  companyOverview    String?  @map("company_overview")
  websiteUrl         String?  @map("website_url")
  desiredWorkAreas   String[] @default([]) @map("desired_work_areas")
  desiredOccupations String[] @default([]) @map("desired_occupations")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  users              User[]

  @@map("organizations")
}

/// ユーザー認証テーブル（Supabase Authと連携）
/// 1つのアカウントで複数の役割を持つことができる
/// organizationIdがnullの場合は個人、nullでない場合は企業ユーザー
model User {
  id                     String                       @id @default(uuid()) @db.Uuid
  email                  String                       @unique
  createdAt              DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime                     @updatedAt @map("updated_at") @db.Timestamptz(6)
  organizationId         String?                      @map("organization_id") @db.Uuid
  stripeCustomerId       String?                      @unique @map("stripe_customer_id") // Stripe Customer ID（支払い方法保存用）
  casterProfile          CasterProfile?
  contractProposals      ContractProposal[]           @relation("ProposedContracts")
  casterMessageThreads   MessageThread[]              @relation("CasterMessageThreads")
  ordererMessageThreads  MessageThread[]              @relation("OrdererMessageThreads")
  sentMessages           Message[]
  orderProjects          OrderProject[]               @relation("OrderProjects")
  ordererProfile         OrdererProfile?
  organization           Organization?                @relation(fields: [organizationId], references: [id])
  // お気に入り関連
  ordererFavorites       OrdererFavoriteCaster[]      @relation("OrdererFavorites")
  casterFavorites        OrdererFavoriteCaster[]      @relation("CasterFavorites")
  casterFavoriteProjects CasterFavoriteOrderProject[] @relation("CasterFavoriteProjects")

  @@index([email])
  @@index([organizationId])
  @@index([stripeCustomerId])
  @@map("users")
}

/// キャスト（受注者）プロフィール
/// 個人として仕事を受注したい人の情報（すべて任意）
/// 企業として受注する場合も、このプロフィールを使用（企業情報はOrganizationに保存）
model CasterProfile {
  id              String               @id @default(uuid()) @db.Uuid
  userId          String               @unique @map("user_id") @db.Uuid
  fullName        String?              @map("full_name")
  area            String?
  occupation      String?
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  onlineAvailable Boolean              @default(false) @map("online_available")
  // 新規追加フィールド
  bio                String?              // 自己紹介
  achievements       String?              // 実績
  mainProfileImage   String?              @map("main_profile_image") // メインプロフィール画像URL
  subProfileImages   String[]             @default([]) @map("sub_profile_images") // サブプロフィール画像URL配列（最大4枚）
  residence          String?              // 居住地
  birthdate          DateTime?            @db.Date // 生年月日
  gender             Gender?              // 性別
  height             Int?                 // 身長(cm)
  weight             Int?                 // 体重(kg)
  snsInstagram       String?              @map("sns_instagram") // Instagram URL
  snsX               String?              @map("sns_x") // X URL
  snsYoutube         String?              @map("sns_youtube") // YouTube URL
  snsFacebook        String?              @map("sns_facebook") // Facebook URL
  workStyle          String?              @map("work_style") // 活動形態（フリーランス、副業、その他）
  minBudget          Int?                 @map("min_budget") // 最低報酬額（円）
  maxBudget          Int?                 @map("max_budget") // 最高報酬額（円）
  // リレーション
  jobTypes        CasterJobType[]
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  travelAreas     CasterTravelArea[]
  workAreas       CasterWorkArea[]
  stripeAccount   CasterStripeAccount?

  @@index([userId])
  @@map("caster_profiles")
}

/// 発注者プロフィール
/// 個人として仕事を依頼したい人の情報（すべて任意）
/// 企業として発注する場合は、Organizationテーブルに企業情報を保存
model OrdererProfile {
  id                 String                @id @default(uuid()) @db.Uuid
  userId             String                @unique @map("user_id") @db.Uuid
  fullName           String?                @map("full_name")
  mainProfileImage   String?                @map("main_profile_image") // メインプロフィール画像URL
  industry           String?                // 業種
  websiteUrl         String[]               @default([]) @map("website_url")
  residence          String?                // 居住地
  desiredWorkAreas   String[]               @default([]) @map("desired_work_areas")
  desiredOccupations String[]               @default([]) @map("desired_occupations")
  createdAt          DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  user               User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  desireWorkAreas    OrderDesireWorkArea[]

  @@index([userId])
  @@map("orderer_profiles")
}

/// 地域ブロックマスター（関東、関西など）
model Region {
  id          String       @id @default(uuid()) @db.Uuid
  code        Int          @unique
  name        String
  nameKana    String?      @map("name_kana")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  prefectures Prefecture[]

  @@index([code])
  @@map("regions")
}

/// 都道府県マスター
model Prefecture {
  id                String                @id @default(uuid()) @db.Uuid
  regionId          String                @map("region_id") @db.Uuid
  code              Int                   @unique
  name              String
  nameKana          String?               @map("name_kana")
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  casterTravelAreas CasterTravelArea[]    @relation("PrefectureTravelAreas")
  casterWorkAreas   CasterWorkArea[]      @relation("PrefectureWorkAreas")
  orderDesireWorkAreas OrderDesireWorkArea[] @relation("PrefectureDesireWorkAreas")
  cities            City[]
  region            Region                @relation(fields: [regionId], references: [id])

  @@index([code])
  @@index([regionId])
  @@map("prefectures")
}

/// 市区町村マスター
model City {
  id                String                @id @default(uuid()) @db.Uuid
  prefectureId      String                @map("prefecture_id") @db.Uuid
  code              String
  name              String
  nameKana          String?               @map("name_kana")
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  casterTravelAreas CasterTravelArea[]    @relation("CityTravelAreas")
  casterWorkAreas   CasterWorkArea[]      @relation("CityWorkAreas")
  orderDesireWorkAreas OrderDesireWorkArea[] @relation("CityDesireWorkAreas")
  prefecture        Prefecture            @relation(fields: [prefectureId], references: [id], onDelete: Cascade)

  @@index([prefectureId])
  @@index([code])
  @@map("cities")
}

/// 東京23区マスター
model TokyoWard {
  id                String                @id @default(uuid()) @db.Uuid
  code              Int                   @unique
  name              String
  nameKana          String?               @map("name_kana")
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  casterTravelAreas CasterTravelArea[]    @relation("TokyoWardTravelAreas")
  casterWorkAreas   CasterWorkArea[]     @relation("TokyoWardWorkAreas")
  orderDesireWorkAreas OrderDesireWorkArea[] @relation("TokyoWardDesireWorkAreas")

  @@index([code])
  @@map("tokyo_wards")
}

/// キャストの稼働エリア
/// 都道府県全体、特定の市区町村、または東京23区を指定可能
/// 複数のエリアを登録できる
model CasterWorkArea {
  id              String        @id @default(uuid()) @db.Uuid
  casterProfileId String        @map("caster_profile_id") @db.Uuid
  prefectureId    String        @map("prefecture_id") @db.Uuid
  cityId          String?       @map("city_id") @db.Uuid
  tokyoWardId     String?       @map("tokyo_ward_id") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  casterProfile   CasterProfile @relation(fields: [casterProfileId], references: [id], onDelete: Cascade)
  city            City?         @relation("CityWorkAreas", fields: [cityId], references: [id], onDelete: Cascade)
  prefecture      Prefecture    @relation("PrefectureWorkAreas", fields: [prefectureId], references: [id], onDelete: Cascade)
  tokyoWard       TokyoWard?    @relation("TokyoWardWorkAreas", fields: [tokyoWardId], references: [id], onDelete: Cascade)

  @@index([casterProfileId])
  @@index([prefectureId])
  @@index([cityId])
  @@index([tokyoWardId])
  @@map("caster_work_areas")
}

/// キャストの出張対応可能範囲
/// 稼働エリアと同様の構造で、出張で対応可能な範囲を指定
model CasterTravelArea {
  id              String        @id @default(uuid()) @db.Uuid
  casterProfileId String        @map("caster_profile_id") @db.Uuid
  prefectureId    String        @map("prefecture_id") @db.Uuid
  cityId          String?       @map("city_id") @db.Uuid
  tokyoWardId     String?       @map("tokyo_ward_id") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  casterProfile   CasterProfile @relation(fields: [casterProfileId], references: [id], onDelete: Cascade)
  city            City?         @relation("CityTravelAreas", fields: [cityId], references: [id], onDelete: Cascade)
  prefecture      Prefecture    @relation("PrefectureTravelAreas", fields: [prefectureId], references: [id], onDelete: Cascade)
  tokyoWard       TokyoWard?    @relation("TokyoWardTravelAreas", fields: [tokyoWardId], references: [id], onDelete: Cascade)

  @@index([casterProfileId])
  @@index([prefectureId])
  @@index([cityId])
  @@index([tokyoWardId])
  @@map("caster_travel_areas")
}

/// 発注者の希望活動エリア
/// 都道府県全体、特定の市区町村、または東京23区を指定可能
/// 複数のエリアを登録できる
model OrderDesireWorkArea {
  id              String         @id @default(uuid()) @db.Uuid
  ordererProfileId String        @map("orderer_profile_id") @db.Uuid
  prefectureId    String         @map("prefecture_id") @db.Uuid
  cityId          String?        @map("city_id") @db.Uuid
  tokyoWardId     String?       @map("tokyo_ward_id") @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  ordererProfile  OrdererProfile @relation(fields: [ordererProfileId], references: [id], onDelete: Cascade)
  city            City?         @relation("CityDesireWorkAreas", fields: [cityId], references: [id], onDelete: Cascade)
  prefecture      Prefecture    @relation("PrefectureDesireWorkAreas", fields: [prefectureId], references: [id], onDelete: Cascade)
  tokyoWard       TokyoWard?    @relation("TokyoWardDesireWorkAreas", fields: [tokyoWardId], references: [id], onDelete: Cascade)

  @@index([ordererProfileId])
  @@index([prefectureId])
  @@index([cityId])
  @@index([tokyoWardId])
  @@map("order_desire_work_areas")
}

/// キャストの職種情報
/// 1人のキャストが複数の職種を持つことができる（例: フォトグラファー兼モデル）
model CasterJobType {
  id              String           @id @default(uuid()) @db.Uuid
  casterProfileId String           @map("caster_profile_id") @db.Uuid
  jobType         JobType          @map("job_type")
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  skills          CasterJobSkill[]
  casterProfile   CasterProfile    @relation(fields: [casterProfileId], references: [id], onDelete: Cascade)

  @@index([casterProfileId])
  @@index([jobType])
  @@map("caster_job_types")
}

/// キャストの職種ごとのスキル/属性
/// 各職種に対して、カテゴリと値のペアで柔軟にスキル情報を保存
/// 例: カテゴリ="撮影ジャンル", 値="ポートレート撮影"
model CasterJobSkill {
  id        String        @id @default(uuid()) @db.Uuid
  jobTypeId String        @map("job_type_id") @db.Uuid
  category  String
  value     String
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  jobType   CasterJobType @relation(fields: [jobTypeId], references: [id], onDelete: Cascade)

  @@index([jobTypeId])
  @@index([category])
  @@map("caster_job_skills")
}

/// メッセージスレッド（会話）
/// 発注者とキャストの間の会話スレッド
model MessageThread {
  id                 String              @id @default(uuid()) @db.Uuid
  ordererId          String              @map("orderer_id") @db.Uuid
  casterId           String              @map("caster_id") @db.Uuid
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  status             MessageThreadStatus @default(scout) @map("status")
  cancellationReason String?             @map("cancellation_reason")
  contractProposals  ContractProposal[]
  orderPayments      OrderPayment[]
  caster             User                @relation("CasterMessageThreads", fields: [casterId], references: [id], onDelete: Cascade)
  orderer            User                @relation("OrdererMessageThreads", fields: [ordererId], references: [id], onDelete: Cascade)
  messages           Message[]

  @@unique([ordererId, casterId])
  @@index([ordererId])
  @@index([casterId])
  @@map("message_threads")
}

/// メッセージ
/// スレッド内の個々のメッセージ
model Message {
  id        String        @id @default(uuid()) @db.Uuid
  threadId  String        @map("thread_id") @db.Uuid
  senderId  String        @map("sender_id") @db.Uuid
  content   String
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  sender    User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  thread    MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([senderId])
  @@index([createdAt])
  @@map("messages")
}

/// 契約条件提示
/// メッセージスレッド内での契約条件の提示を記録
model ContractProposal {
  id             String         @id @default(uuid()) @db.Uuid
  threadId       String         @map("thread_id") @db.Uuid
  proposerId     String         @map("proposer_id") @db.Uuid
  contractAmount Int            @map("contract_amount")
  projectContent String         @map("project_content")
  completionDate DateTime       @map("completion_date") @db.Date
  isAgreed       Boolean        @default(false) @map("is_agreed")
  agreedAt       DateTime?      @map("agreed_at") @db.Timestamptz(6)
  agreedBy       String?        @map("agreed_by") @db.Uuid
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  proposer       User           @relation("ProposedContracts", fields: [proposerId], references: [id], onDelete: Cascade)
  thread         MessageThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  orderPayments  OrderPayment[]

  @@index([threadId])
  @@index([proposerId])
  @@index([createdAt])
  @@map("contract_proposals")
}

/// 発注者からの決済情報
/// 発注者が弊社に仮払いする決済を管理
model OrderPayment {
  id                 String @id @default(uuid()) @db.Uuid
  contractProposalId String @map("contract_proposal_id") @db.Uuid
  threadId           String @map("thread_id") @db.Uuid
  ordererId          String @map("orderer_id") @db.Uuid
  casterId           String @map("caster_id") @db.Uuid

  // Stripe関連のID
  stripePaymentIntentId   String? @map("stripe_payment_intent_id")
  stripeCheckoutSessionId String? @map("stripe_checkout_session_id")

  // 金額情報（単位：円）
  totalAmount  Int @map("total_amount") // 契約金額（仮払い）
  platformFee  Int @map("platform_fee") // 手数料（20%）
  casterAmount Int @map("caster_amount") // 受注者への支払額（80%）

  // ステータス
  status OrderPaymentStatus @default(pending)

  // タイムスタンプ
  paidAt DateTime? @map("paid_at") @db.Timestamptz(6) // 決済完了日時

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  contractProposal ContractProposal @relation(fields: [contractProposalId], references: [id], onDelete: Cascade)
  thread           MessageThread    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  casterPayout     CasterPayout? // 受注者への送金情報（1対1）

  @@index([contractProposalId])
  @@index([threadId])
  @@index([ordererId])
  @@index([casterId])
  @@index([status])
  @@index([stripePaymentIntentId])
  @@index([stripeCheckoutSessionId])
  @@map("order_payments")
}

/// 受注者への送金情報
/// 納品後に受注者に送金する情報を管理
model CasterPayout {
  id             String @id @default(uuid()) @db.Uuid
  orderPaymentId String @unique @map("order_payment_id") @db.Uuid
  casterId       String @map("caster_id") @db.Uuid

  // Stripe関連のID
  stripeTransferId String? @map("stripe_transfer_id") // Stripe Transfer ID

  // 金額情報（単位：円）
  amount Int // 送金額（OrderPayment.casterAmountと同じ値）

  // ステータス
  status CasterPayoutStatus @default(pending)

  // タイムスタンプ
  deliveredAt   DateTime? @map("delivered_at") @db.Timestamptz(6) // 納品日時
  transferredAt DateTime? @map("transferred_at") @db.Timestamptz(6) // 送金完了日時

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  orderPayment OrderPayment @relation(fields: [orderPaymentId], references: [id], onDelete: Cascade)

  @@index([orderPaymentId])
  @@index([casterId])
  @@index([status])
  @@index([stripeTransferId])
  @@map("caster_payouts")
}

/// 受注者のStripe Connectアカウント情報
/// Stripe Connectを使用して受注者に送金するためのアカウント情報を管理
/// メールアドレスはUserテーブルから取得するため、ここには保存しない
model CasterStripeAccount {
  id              String @id @default(uuid()) @db.Uuid
  casterProfileId String @unique @map("caster_profile_id") @db.Uuid
  stripeAccountId String @unique @map("stripe_account_id") // Stripe ConnectアカウントID（acct_xxxxx）

  // アカウント情報（Stripe APIから取得可能だが、パフォーマンスのためにキャッシュ）
  businessType String? @map("business_type") // individual, company
  country      String? // 国コード（例: JP）

  // アカウントステータス
  isActive       Boolean @default(false) @map("is_active") // アカウントが有効かどうか
  isVerified     Boolean @default(false) @map("is_verified") // 本人確認が完了しているか
  chargesEnabled Boolean @default(false) @map("charges_enabled") // 受金が有効か（通常はfalse、送金のみ）
  payoutsEnabled Boolean @default(false) @map("payouts_enabled") // 送金が有効か

  // 口座情報（Stripeが管理、ここでは参照のみ）
  // 実際の口座情報はStripe APIで取得する

  // タイムスタンプ
  connectedAt DateTime? @map("connected_at") @db.Timestamptz(6) // Stripe Connectアカウント作成日時
  verifiedAt  DateTime? @map("verified_at") @db.Timestamptz(6) // 本人確認完了日時
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  casterProfile CasterProfile @relation(fields: [casterProfileId], references: [id], onDelete: Cascade)

  @@index([casterProfileId])
  @@index([stripeAccountId])
  @@index([isActive])
  @@index([payoutsEnabled])
  @@map("caster_stripe_accounts")
}

/// 案件登録
/// 発注者が登録した案件情報
model OrderProject {
  id              String                       @id @default(uuid()) @db.Uuid
  userId          String                       @map("user_id") @db.Uuid
  category        JobType
  title           String
  detail          String
  minBudget       Int                          @map("min_budget")
  maxBudget       Int                          @map("max_budget")
  createdAt       DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime                     @updatedAt @map("updated_at") @db.Timestamptz(6)
  user            User                         @relation("OrderProjects", fields: [userId], references: [id], onDelete: Cascade)
  casterFavorites CasterFavoriteOrderProject[] @relation("CasterFavoriteOrderProjects")

  @@index([userId])
  @@index([category])
  @@index([createdAt])
  @@map("order_projects")
}

/// キャストのお気に入り案件
/// キャストがお気に入り登録した案件を管理
model CasterFavoriteOrderProject {
  id        String @id @default(uuid()) @db.Uuid
  casterId  String @map("caster_id") @db.Uuid // キャストのユーザーID
  projectId String @map("project_id") @db.Uuid // 案件のID

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  caster  User         @relation("CasterFavoriteProjects", fields: [casterId], references: [id], onDelete: Cascade)
  project OrderProject @relation("CasterFavoriteOrderProjects", fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([casterId, projectId]) // 同じキャストと案件の組み合わせは1つのみ
  @@index([casterId])
  @@index([projectId])
  @@map("caster_favorite_order_projects")
}

/// 発注者のお気に入りキャスト
/// 発注者がお気に入り登録したキャストを管理
model OrdererFavoriteCaster {
  id        String @id @default(uuid()) @db.Uuid
  ordererId String @map("orderer_id") @db.Uuid // 発注者のユーザーID
  casterId  String @map("caster_id") @db.Uuid // キャストのユーザーID

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  orderer User @relation("OrdererFavorites", fields: [ordererId], references: [id], onDelete: Cascade)
  caster  User @relation("CasterFavorites", fields: [casterId], references: [id], onDelete: Cascade)

  @@unique([ordererId, casterId]) // 同じ発注者とキャストの組み合わせは1つのみ
  @@index([ordererId])
  @@index([casterId])
  @@map("orderer_favorite_casters")
}

enum Gender {
  male
  female
  other
  prefer_not_to_say
}

enum JobType {
  photographer
  model
  artist
  creator
}

/// メッセージスレッドのステータス
/// 発注者と受注者の間の会話スレッドの進行状況を管理
enum MessageThreadStatus {
  scout // 応募・スカウト（初期状態）
  negotiation // 条件交渉中
  agreed // 条件合意済み
  contract // 契約（決済完了後）
  CasterCancelRequesting // キャスト側からの途中中断リクエスト中
  OrderCancelRequesting // 発注者側からの途中中断リクエスト中
  DeliveredAndReviewing // 納品済み・検収中
  completed // 完了
  cancelled // キャンセル
}

/// 発注者からの決済ステータス
enum OrderPaymentStatus {
  pending // 決済待ち
  paid // 支払い完了（仮払い済み）
  cancelled // キャンセル
}

/// 受注者への送金ステータス
enum CasterPayoutStatus {
  pending // 送金待ち（納品前）
  delivered // 納品済み（送金可能）
  transferred // 送金完了
  cancelled // キャンセル
}
